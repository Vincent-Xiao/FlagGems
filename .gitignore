# Build and Release Folders
bin-debug/
bin-release/
[Oo]bj/
[Bb]in/

# Other files and folders
.settings/
__pycache__/
.vscode/

# Python venv directory
.venv

# Distribution files
build/
*.egg-info/
.eggs/
dist/

# scikit-build-core
.skbuild-info.json
CMakeInit.txt

# An auxiliary product of unittests
tests/*.json


# Executables
*.swf
*.air
*.ipa
*.apk

# Project files, i.e. `.project`, `.actionScriptProperties` and `.flexProperties`
# should NOT be excluded as they contain compiler settings and other important
# information for Eclipse / Flash Builder.

# --- appended rules (after line 38) ---
# Ignore specific top-level outputs
log/
=0.11

# Ignore everything under flagtune by default
flagtune/**

# Keep directory traversal
!flagtune/
!flagtune/**/

# Allow scripts under flagtune
!flagtune/**/*.py
!flagtune/**/*.sh

# Allow tune-config directory and its contents
!flagtune/tune-config/
!flagtune/tune-config/**

